# ── PROJEKT ──
PROJECT_NAME=designflow
DATA_DIR=/opt/infrakit/data

# ── EGYSÉGES ADMINISZTRÁCIÓ (Alapértelmezett login adatok az új felületekhez) ──
ADMIN_EMAIL=admin@designflow.hu
ADMIN_PASSWORD=change_this_very_secure_password_for_panel

# ── POSTGRESQL ──
DB_NAME=designflow
DB_USER=designflow
PG_MEMORY_LIMIT=512M

# ── PGBOUNCER ──
PGBOUNCER_PORT=6432
PGBOUNCER_MAX_CONN=200
PGBOUNCER_POOL_SIZE=20

# ── VALKEY ──
VALKEY_PORT=6379
VALKEY_MAXMEMORY=128mb
VALKEY_MEMORY_LIMIT=192M
VALKEY_PERSISTENT=true
# false = pure cache (adat elvész restart-nál)
# true  = AOF + RDB mentés (adat megmarad)

# ── GARAGE (S3 storage) ──
STORAGE_API_PORT=3900
STORAGE_BUCKET=designflow-files
STORAGE_CAPACITY=1G
GARAGE_MEMORY_LIMIT=256M
GARAGE_S3_API_DOMAIN=https://s3.designflow.hu

# ── GLITCHTIP (error tracking) ──
GLITCHTIP_PORT=8000
GLITCHTIP_DOMAIN=https://errors.designflow.hu
GLITCHTIP_FROM_EMAIL=errors@designflow.hu
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_EVENT_RETENTION=90

# ── MONITORING + WEB UIs (Belső, VPN-en keresztül) ──
KUMA_PORT=3001
UPTIME_KUMA_DOMAIN=http://infrakit-secure:3001
FILESTASH_PORT=8334
FILESTASH_DOMAIN=http://infrakit-secure:8334
ADMINER_PORT=8080
ADMINER_DOMAIN=http://infrakit-secure:8080

# ── AUTO-GENERÁLT (Coolify magic variables, 64 karakter) ──
# SERVICE_PASSWORD_64_POSTGRES=
# SERVICE_PASSWORD_64_VALKEY=
# SERVICE_PASSWORD_64_GARAGE_RPC=
# SERVICE_PASSWORD_64_GARAGE_ADMIN=
# SERVICE_PASSWORD_64_GARAGE_ACCESS=
# SERVICE_PASSWORD_64_GARAGE_SECRET=
# SERVICE_PASSWORD_64_GLITCHTIP=

# ── INFRAPANEL (Saját Dashboard, VPN-en keresztül) ──
INFRAPANEL_DOMAIN=http://infrakit-secure:3000

# ── TAILSCALE VPN ──
# Generálj egy "Reusable" és "Ephemeral" (nem kötelező) auth key-t a login.tailscale.com-on:
TAILSCALE_AUTHKEY=tskey-auth-xxxxx-xxxxxxxx
